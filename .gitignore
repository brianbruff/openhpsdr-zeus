# Dependencies
client/node_modules/
client/dist/
zeus-web/node_modules/
zeus-web/dist/
zeus-web/dev-dist/
Zeus.Server/wwwroot/

# TypeScript incremental-build cache — rewritten on every `tsc -b`, never code
*.tsbuildinfo

# .NET
**/bin/
**/obj/
**/*.user
**/*.suo
**/*.lscache
*.nupkg

# IDE
.vs/
.vscode/
*.swp
*.swo

# OS
Thumbs.db
.DS_Store

# Logs
*.log
tools/demo-server/bin/
tools/demo-server/obj/
# Claude Code: share skills/commands/agents, keep per-machine state local
.claude/settings.local.json
.claude/*.lock

# Local credential store (LiteDB) — stored in user's app-data dir, never in repo
zeus.db*
.dbkey

# Native WDSP build cache. The staged library under
# Zeus.Dsp/runtimes/<rid>/native/ IS committed so managed-side tests
# don't need to run CMake before executing.
native/build/

# Playwright-MCP accessibility snapshots and console logs — regenerated
# on every browser-automation run; do not track.
.playwright-mcp/

# Ad-hoc screenshot captures (debug PNGs) in the repo root. Real docs
# imagery lives under docs/ when we need it.
/*.png
